<!DOCTYPE html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard - WanderLodge</title>
    <link rel="stylesheet" href="/css/style.css" />
    <link rel="stylesheet" href="/css/components.css" />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css"
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&display=swap"
      rel="stylesheet"
    />
    <style>
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
        background: var(--bg-secondary);
        color: var(--text-primary);
      }

      .admin-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 2rem;
      }

      .admin-header {
        margin-bottom: 3rem;
      }

      .admin-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .admin-header p {
        color: var(--text-secondary);
        font-size: 1rem;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
        margin-bottom: 3rem;
      }

      .stat-card {
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        transition: all 0.3s ease;
      }

      .stat-card:hover {
        border-color: var(--primary);
        box-shadow: 0 4px 12px rgba(13, 148, 136, 0.1);
      }

      .stat-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 1rem;
      }

      .stat-card-title {
        font-size: 0.9rem;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-weight: 600;
      }

      .stat-card-icon {
        font-size: 1.5rem;
        color: var(--primary);
        opacity: 0.7;
      }

      .stat-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--text-primary);
        margin-bottom: 0.5rem;
      }

      .stat-change {
        font-size: 0.85rem;
        color: var(--success);
        display: flex;
        align-items: center;
        gap: 0.25rem;
      }

      .section {
        background: var(--bg-primary);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 2rem;
        margin-bottom: 2rem;
      }

      .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--border-color);
      }

      .section-header h2 {
        font-size: 1.3rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .section-header a {
        color: var(--primary);
        text-decoration: none;
        font-size: 0.9rem;
        transition: color 0.3s ease;
      }

      .section-header a:hover {
        color: var(--primary-dark);
      }

      .table {
        width: 100%;
        border-collapse: collapse;
      }

      .table th {
        background: var(--bg-secondary);
        padding: 1rem;
        text-align: left;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
        border-bottom: 2px solid var(--border-color);
      }

      .table td {
        padding: 1rem;
        border-bottom: 1px solid var(--border-color);
      }

      .table tr:hover {
        background: var(--bg-secondary);
      }

      .status-badge {
        display: inline-block;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: capitalize;
      }

      .status-pending {
        background: rgba(249, 115, 22, 0.1);
        color: #ea580c;
      }

      .status-resolved {
        background: rgba(34, 197, 94, 0.1);
        color: #16a34a;
      }

      .status-active {
        background: rgba(34, 197, 94, 0.1);
        color: #16a34a;
      }

      .status-banned {
        background: rgba(239, 68, 68, 0.1);
        color: #dc2626;
      }

      .status-inactive {
        background: rgba(107, 114, 128, 0.1);
        color: #6b7280;
      }

      .action-btn {
        padding: 0.5rem 1rem;
        background: var(--primary);
        color: white;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.85rem;
        transition: all 0.3s ease;
      }

      .action-btn:hover {
        background: var(--primary-dark);
      }

      .admin-nav {
        display: flex;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
      }

      .nav-btn {
        padding: 0.75rem 1.5rem;
        background: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        color: var(--text-primary);
        text-decoration: none;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .nav-btn:hover,
      .nav-btn.active {
        background: var(--primary);
        color: white;
        border-color: var(--primary);
      }

      .empty-state {
        text-align: center;
        padding: 2rem;
        color: var(--text-secondary);
      }

      .empty-state i {
        font-size: 2rem;
        margin-bottom: 1rem;
        opacity: 0.5;
      }

      @media (max-width: 768px) {
        .admin-container {
          padding: 1rem;
        }

        .admin-header h1 {
          font-size: 1.5rem;
        }

        .stats-grid {
          grid-template-columns: 1fr;
        }

        .section-header {
          flex-direction: column;
          align-items: flex-start;
          gap: 1rem;
        }

        .table {
          font-size: 0.9rem;
        }

        .table th,
        .table td {
          padding: 0.75rem;
        }

        .admin-nav {
          flex-direction: column;
        }

        .nav-btn {
          width: 100%;
          justify-content: center;
        }
      }
    </style>
  </head>

  <body>
    <%- include("../includes/navbar.ejs") %>

    <main>
      <div class="admin-container">
        <%- include("../includes/flash.ejs") %>

        <div class="admin-header">
          <h1><i class="fas fa-chart-line"></i> Admin Dashboard</h1>
          <p>Platform overview and management tools</p>
        </div>

        <div class="admin-nav">
          <a href="/admin" class="nav-btn active">
            <i class="fas fa-dashboard"></i> Dashboard
          </a>
          <a href="/admin/users" class="nav-btn">
            <i class="fas fa-users"></i> Users
          </a>
          <a href="/admin/listings" class="nav-btn">
            <i class="fas fa-home"></i> Listings
          </a>
          <a href="/admin/reports" class="nav-btn">
            <i class="fas fa-flag"></i> Reports
          </a>
          <a href="/admin/analytics" class="nav-btn">
            <i class="fas fa-chart-bar"></i> Analytics
          </a>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Total Users</span>
              <i class="fas fa-users stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.users.total %></div>
            <div class="stat-change">
              <i class="fas fa-arrow-up"></i>
              <%= stats.users.newThisMonth %> new this month
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Active Users</span>
              <i class="fas fa-user-check stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.users.active %></div>
            <div class="stat-change">
              <span><%= Math.round((stats.users.active / stats.users.total) * 100) %>% active</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Banned Users</span>
              <i class="fas fa-ban stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.users.banned %></div>
            <div class="stat-change">
              <span>Monitor activity</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Total Listings</span>
              <i class="fas fa-home stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.listings.total %></div>
            <div class="stat-change">
              <span><%= stats.listings.active %> active</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Flagged Listings</span>
              <i class="fas fa-exclamation-triangle stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.listings.flagged %></div>
            <div class="stat-change">
              <span>Need review</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Total Bookings</span>
              <i class="fas fa-calendar-check stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.bookings.total %></div>
            <div class="stat-change">
              <span>Active bookings</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Total Revenue</span>
              <i class="fas fa-dollar-sign stat-card-icon"></i>
            </div>
            <div class="stat-value">$<%= stats.revenue.total.toFixed(2) %></div>
            <div class="stat-change">
              <span>All time</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Monthly Revenue</span>
              <i class="fas fa-chart-line stat-card-icon"></i>
            </div>
            <div class="stat-value">$<%= stats.revenue.thisMonth.toFixed(2) %></div>
            <div class="stat-change">
              <span>This month</span>
            </div>
          </div>

          <div class="stat-card">
            <div class="stat-card-header">
              <span class="stat-card-title">Pending Approvals</span>
              <i class="fas fa-hourglass-half stat-card-icon"></i>
            </div>
            <div class="stat-value"><%= stats.reports.pendingApprovals %></div>
            <div class="stat-change">
              <span>Awaiting action</span>
            </div>
          </div>
        </div>

        <div class="section">
          <div class="section-header">
            <h2><i class="fas fa-flag"></i> Recent Reports</h2>
            <a href="/admin/reports">View All</a>
          </div>

          <% if (recentReports.length > 0) { %>
            <table class="table">
              <thead>
                <tr>
                  <th>Type</th>
                  <th>Reported By</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                <% recentReports.forEach(report => { %>
                  <tr>
                    <td>
                      <strong><%= report.reportType %></strong>
                    </td>
                    <td><%= report.reportedBy?.username || 'Unknown' %></td>
                    <td>
                      <span
                        class="status-badge status-<%= report.status %>"
                      >
                        <%= report.status %>
                      </span>
                    </td>
                    <td>
                      <%= new Date(report.createdAt).toLocaleDateString() %>
                    </td>
                    <td>
                      <a href="/admin/reports" class="action-btn">
                        Review
                      </a>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state">
              <i class="fas fa-inbox"></i>
              <p>No recent reports</p>
            </div>
          <% } %>
        </div>

        <div class="section">
          <div class="section-header">
            <h2><i class="fas fa-history"></i> Recent Admin Actions</h2>
          </div>

          <% if (recentActions.length > 0) { %>
            <table class="table">
              <thead>
                <tr>
                  <th>Admin</th>
                  <th>Action</th>
                  <th>Description</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                <% recentActions.forEach(action => { %>
                  <tr>
                    <td><%= action.adminUser?.username || 'System' %></td>
                    <td>
                      <strong><%= action.action.replace("-", " ") %></strong>
                    </td>
                    <td><%= action.description %></td>
                    <td>
                      <%= new Date(action.createdAt).toLocaleDateString() %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } else { %>
            <div class="empty-state">
              <i class="fas fa-inbox"></i>
              <p>No recent actions</p>
            </div>
          <% } %>
        </div>

        <div class="section">
          <div class="section-header">
            <h2><i class="fas fa-download"></i> Export Reports</h2>
          </div>
          <div class="admin-nav" style="border-top: 1px solid var(--border-color); padding-top: 1rem;">
            <a href="/admin/export?type=summary" class="nav-btn">
              <i class="fas fa-file-download"></i> Summary Report
            </a>
            <a href="/admin/export?type=users" class="nav-btn">
              <i class="fas fa-file-download"></i> Users Report
            </a>
            <a href="/admin/export?type=listings" class="nav-btn">
              <i class="fas fa-file-download"></i> Listings Report
            </a>
            <a href="/admin/export?type=bookings" class="nav-btn">
              <i class="fas fa-file-download"></i> Bookings Report
            </a>
          </div>
        </div>
      </div>
    </main>

    <%- include("../includes/footer.ejs") %>
    <script src="/js/main.js"></script>
    <script src="/js/theme.js"></script>
  </body>
</html>